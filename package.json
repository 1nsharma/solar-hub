{
  "name": "solar-hub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -ws",
    "start": "concurrently -n \"BACKEND,WEB,MOBILE\" -c \"bgBlue,bgGreen,bgYellow\" --kill-others \"npm run dev:backend\" \"wait-on http://localhost:5001/api/health && npm run dev:web\" \"wait-on http://localhost:5001/api/health && npm run dev:mobile\"",
    "dev:web": "npm run dev -w @solar-hub/web-admin",
    "dev:backend": "npm run dev -w @solar-hub/backend",
    "dev:mobile": "npm run start -w mobile -- --port 8082",
    "build:web": "npm run build -w @solar-hub/web-admin",
    "build:mobile:web": "npm run web -w mobile",
    "build:apk": "npm run build:apk -w mobile",
    "build:vendor:apk": "npm run build:vendor:apk -w mobile",
    "build:vendor:aab": "npm run build:vendor:aab -w mobile",
    "test:backend": "npm run test -w @solar-hub/backend",
    "lint": "npm run lint -w @solar-hub/web-admin && npm run lint -w mobile",
    "release:check": "npm run lint && npm run build:web && npm run test:backend",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "expo": "~54.0.34",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "wait-on": "^9.0.5"
  }
}
