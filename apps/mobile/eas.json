{
  "cli": {
    "version": ">= 13.0.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "customer",
        "EXPO_PUBLIC_API_URL": "https://staging-api.solarhub.in"
      }
    },
    "vendor-apk": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "vendor",
        "EXPO_PUBLIC_API_URL": "https://staging-api.solarhub.in"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_VARIANT": "customer",
        "EXPO_PUBLIC_API_URL": "https://api.solarhub.in"
      }
    },
    "vendor-production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_VARIANT": "vendor",
        "EXPO_PUBLIC_API_URL": "https://api.solarhub.in"
      }
    },
    "technician-apk": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "technician",
        "EXPO_PUBLIC_API_URL": "https://staging-api.solarhub.in"
      }
    },
    "technician-production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_VARIANT": "technician",
        "EXPO_PUBLIC_API_URL": "https://api.solarhub.in"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
