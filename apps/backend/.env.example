# Server Config
PORT=5000
USE_MOCK=true

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/solarhub

# Payment Gateway (Razorpay/Stripe)
PAYMENT_GATEWAY_KEY=rzp_test_XXXXXXXXXXXXXX
PAYMENT_GATEWAY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Logistics (Shiprocket)
SHIPROCKET_EMAIL=admin@solarhub.in
SHIPROCKET_PASSWORD=XXXXXXXXXXXXXXXX

# Notifications (Twilio)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_PHONE_NUMBER=+1234567890

# Maps (Google Maps)
GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Analytics (GA4/Mixpanel)
GA_MEASUREMENT_ID=G-XXXXXXXXXX
MIXPANEL_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Storage (S3 / R2)
STORAGE_BUCKET=solarhub-media
STORAGE_REGION=ap-south-1
STORAGE_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXX
STORAGE_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

